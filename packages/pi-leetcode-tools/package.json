{
  "name": "pi-leetcode-tools",
  "version": "0.1.2",
  "description": "Unofficial native Pi tool calls for LeetCode Global and CN",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Li7777777/pi-leetcode-tools.git"
  },
  "homepage": "https://github.com/Li7777777/pi-leetcode-tools#readme",
  "bugs": {
    "url": "https://github.com/Li7777777/pi-leetcode-tools/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "tool-call",
    "leetcode-tools"
  ],
  "files": [
    "dist",
    "contract",
    "upstream",
    "README.md",
    "README.zh-CN.md",
    "SECURITY.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "pi-leetcode": "./dist/src/cli.js"
  },
  "exports": {
    "./embedded": {
      "types": "./dist/src/embedded.d.ts",
      "import": "./dist/src/embedded.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "import": "./dist/src/types.js"
    },
    "./contract": {
      "types": "./dist/src/tool-calls/contract.d.ts",
      "import": "./dist/src/tool-calls/contract.js"
    }
  },
  "pi": {
    "extensions": [
      "./dist/extensions/index.js"
    ]
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json && node ./scripts/write-contract.mjs",
    "typecheck": "npm run typecheck:src && npm run typecheck:tests",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "verify:upstream-parity:report": "node ./scripts/verify-upstream-parity.mjs --json",
    "verify:upstream-parity": "node ./scripts/verify-upstream-parity.mjs --require-complete --json",
    "verify:upstream-completeness:source": "node ./scripts/verify-upstream-completeness.mjs --source-only --json",
    "verify:upstream-completeness": "node ./scripts/verify-upstream-completeness.mjs --json",
    "verify:upstream-adapter-fixtures": "npm run build && node ./scripts/verify-upstream-adapter-fixtures.mjs ../../.artifacts/tools ../../release/candidates/tools",
    "verify:release-artifact": "node ./scripts/verify-release-artifact.mjs",
    "prepublishOnly": "npm run verify:release-artifact && npm run verify:upstream-completeness:source",
    "prepack": "npm run verify:release-artifact && npm run verify:upstream-completeness:source"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "html-to-text": "^9.0.5",
    "playwright-core": "^1.61.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "typebox": "1.1.38",
    "vitest": "^3.2.4"
  }
}
